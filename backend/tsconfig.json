{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/*"]
    },
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "app/**/*.ts",
    "config/**/*.ts",
    "database/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
