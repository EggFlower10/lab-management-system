.cover-card,
.detail-panel,
.qr-panel {
  margin-top: 22rpx;
}

.detail-panel,
.qr-panel {
  padding: 28rpx;
}

.lab-cover {
  width: 100%;
  height: 260rpx;
  border-radius: 28rpx;
}

.cover-surface {
  box-sizing: border-box;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background:
    radial-gradient(circle at top right, rgba(133, 209, 255, 0.9), transparent 34%),
    linear-gradient(135deg, #143a86 0%, #286fd3 60%, #6cb6ff 100%);
  color: #ffffff;
}

.cover-badge {
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
}

.cover-name {
  margin-top: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.qr-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.qr-grid {
  padding: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f3f7ff 100%);
  border-radius: 24rpx;
  box-shadow: inset 0 0 0 1rpx #e4ecfa;
}

.qr-row {
  display: flex;
}

.qr-cell {
  width: 16rpx;
  height: 16rpx;
  background: #e7edf7;
}

.qr-cell.active {
  background: #10254d;
}

.qr-code-text {
  margin-top: 20rpx;
  color: #244f97;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.qr-placeholder {
  width: 100%;
  padding: 48rpx 24rpx;
  border-radius: 24rpx;
  background: #f6f8fc;
  color: #72829d;
  text-align: center;
}

.detail-info-list {
  width: 100%;
  margin-top: 24rpx;
}

.card-line-stack {
  align-items: flex-start;
}

.stack-text {
  max-width: 420rpx;
  text-align: right;
  line-height: 1.6;
}
