<view class="page-shell without-tabbar">
  <view class="section-header">
    <text class="section-title">我的预约</text>
    <text class="section-meta">支持查看状态、详情与取消操作</text>
  </view>

  <view class="capsule-row">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="capsule {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="changeTab"
    >
      {{item.label}}
    </view>
  </view>

  <block wx:if="{{reservations.length}}">
    <view wx:for="{{reservations}}" wx:key="id" class="list-card">
      <view class="card-title-row">
        <view>
          <text class="card-title">{{item.labName}}</text>
          <text class="card-subtitle">{{item.projectName}}</text>
        </view>
        <text class="status-tag {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="card-line">
        <text>{{item.date}} {{item.timeSlot}}</text>
        <text>{{item.headCount}} 人</text>
      </view>
      <view class="card-line">
        <text>预约编号</text>
        <text class="meta-text">{{item.code}}</text>
      </view>
      <view class="btn-row">
        <button class="btn-secondary" data-id="{{item.id}}" bindtap="openDetail">查看详情</button>
        <button class="btn-light" wx:if="{{item.status === 'pending' || item.status === 'approved'}}" data-id="{{item.id}}" bindtap="handleCancel">取消预约</button>
      </view>
    </view>
  </block>
  <view wx:else class="empty-card">当前分类下还没有预约记录。</view>
</view>
