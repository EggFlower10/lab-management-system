.stat-grid {
  margin-top: 20rpx;
}

.stat-card {
  padding: 24rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #6f7f98;
}

.stat-value {
  display: block;
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #16345f;
}

.stat-intro {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8aa3;
}

.notice-card,
.process-card {
  margin-top: 20rpx;
}

.notice-card {
  padding: 28rpx;
}

.warning-card {
  background: linear-gradient(180deg, #fff7ef 0%, #ffffff 100%);
  border: 1rpx solid #ffd9b0;
}

.admin-card {
  background: linear-gradient(180deg, #eef6ff 0%, #ffffff 100%);
  border: 1rpx solid #d6e4ff;
}

.notice-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #183153;
}

.notice-text {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #37517f;
}

.notice-hint {
  display: block;
  margin-top: 14rpx;
  color: #7b8aa3;
}

.compact-header {
  margin: 0 0 20rpx;
}

.process-list {
  display: grid;
  gap: 16rpx;
}

.process-item {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f6f8fc;
}

.process-step {
  font-size: 22rpx;
  font-weight: 700;
  color: #2a74d7;
}

.process-name {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2a44;
}

.process-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #718099;
}

.title-wrap {
  flex: 1;
}

.meta-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.meta-block {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f6f8fc;
}

.meta-label {
  font-size: 22rpx;
  color: #7b8aa3;
}

.meta-value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2a44;
}

.inline-alert {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(219, 72, 72, 0.08);
  color: #b73131;
  font-size: 24rpx;
  line-height: 1.6;
}

.request-card {
  margin-top: 20rpx;
}

.request-purpose {
  margin-top: 18rpx;
}
