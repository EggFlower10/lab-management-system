.login-page {
  background:
    radial-gradient(circle at top right, rgba(70, 144, 255, 0.22), transparent 34%),
    linear-gradient(180deg, #f2f7ff 0%, #f7f9fc 100%);
}

.login-hero {
  padding: 28rpx 8rpx 12rpx;
}

.hero-kicker {
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(28, 79, 161, 0.1);
  color: #245ab4;
  font-size: 22rpx;
}

.login-title {
  display: block;
  margin-top: 28rpx;
  font-size: 52rpx;
  font-weight: 700;
  color: #17325f;
}

.login-subtitle {
  display: block;
  margin-top: 18rpx;
  line-height: 1.7;
  color: #5f7190;
}

.login-header {
  margin-top: 24rpx;
}

.role-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
}

.role-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(19, 62, 123, 0.08);
}

.role-card.active {
  background: linear-gradient(135deg, #17408b 0%, #2a74d7 100%);
}

.role-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1e2d4d;
}

.role-card.active .role-title,
.role-card.active .role-intro {
  color: #ffffff;
}

.role-intro {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6d7d96;
}

.login-form {
  margin-top: 28rpx;
}

.auth-card {
  margin-top: 28rpx;
}

.compact-header {
  margin-top: 0;
}

.wechat-desc {
  display: block;
  margin-top: 12rpx;
  color: #6d7d96;
  font-size: 24rpx;
  line-height: 1.7;
}

.account-tip {
  margin: 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  color: #6d7d96;
  font-size: 24rpx;
}

.login-button {
  margin-top: 12rpx;
}
