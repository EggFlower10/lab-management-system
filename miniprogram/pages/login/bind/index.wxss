.login-page {
  background:
    radial-gradient(circle at top right, rgba(70, 144, 255, 0.22), transparent 34%),
    linear-gradient(180deg, #f2f7ff 0%, #f7f9fc 100%);
}

.hero-title,
.hero-subtitle,
.helper-text {
  display: block;
}

.summary-card,
.bind-form {
  margin-top: 28rpx;
}

.helper-text {
  margin-top: 12rpx;
  color: #7b8aa3;
  font-size: 22rpx;
  line-height: 1.6;
}

.phone-row {
  margin-top: 16rpx;
}

.tiny-btn {
  font-size: 24rpx;
  height: 76rpx;
}

.auth-note {
  margin-top: 28rpx;
  padding: 24rpx;
}
