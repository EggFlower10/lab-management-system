.cover-card,
.detail-card {
  margin-top: 18rpx;
}

.detail-card {
  padding: 28rpx;
}

.lab-cover {
  width: 100%;
  height: 280rpx;
  border-radius: 28rpx 28rpx 0 0;
}

.cover-surface {
  box-sizing: border-box;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  background:
    radial-gradient(circle at top right, rgba(126, 196, 255, 0.9), transparent 32%),
    linear-gradient(135deg, #153a88 0%, #2e77d8 62%, #70bdff 100%);
  color: #ffffff;
}

.cover-badge {
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  font-size: 22rpx;
}

.cover-name {
  margin-top: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.cover-caption {
  padding: 24rpx 28rpx 28rpx;
}

.cover-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1d3054;
}

.cover-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d7e98;
}

.compact {
  margin: 0 0 20rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.summary-card {
  padding: 26rpx 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(15, 52, 115, 0.08);
  text-align: center;
}

.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #19448f;
}

.summary-label {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #70809a;
}

.card-line-stack {
  align-items: flex-start;
}

.stack-text {
  max-width: 420rpx;
  text-align: right;
  line-height: 1.6;
}

.sticky-actions {
  margin-top: 28rpx;
}
