.hero-title,
.hero-subtitle {
  display: block;
}

.overview-grid {
  margin-top: 24rpx;
}

.stock-stat-card {
  padding: 28rpx;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #17325f;
}

.stat-label {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2a44;
}

.stat-intro {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7b8aa3;
  line-height: 1.5;
}

.compact-header {
  margin-top: 0;
}

.warning-card,
.operation-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.warning-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.warning-item {
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 243, 243, 0.86);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.warning-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #8f2c2c;
}

.warning-detail {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a6161;
}

.warning-action {
  flex: none;
  width: 168rpx;
  height: 72rpx;
  font-size: 24rpx;
}

.mode-row,
.filter-row {
  margin-top: 16rpx;
}

.panel-desc {
  display: block;
  margin-top: 18rpx;
  color: #6f7f98;
  font-size: 24rpx;
  line-height: 1.7;
}

.selected-summary {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f7faff;
}

.helper-text {
  display: block;
  margin-top: 12rpx;
  color: #7b8aa3;
  font-size: 22rpx;
  line-height: 1.6;
}

.preview-box {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #eef6ff;
}

.preview-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #1e4d95;
}

.preview-text {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #48638b;
  line-height: 1.6;
}

.stock-card {
  margin-top: 20rpx;
}
