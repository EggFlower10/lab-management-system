<view class="page-shell without-tabbar">
  <view class="section-header">
    <text class="section-title">审批中心</text>
    <text class="section-meta">{{subtitle}}</text>
  </view>

  <view class="capsule-row">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="capsule {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="changeTab"
    >
      {{item.label}}
    </view>
  </view>

  <block wx:if="{{list.length}}">
    <view wx:for="{{list}}" wx:key="id" class="list-card">
      <view class="card-title-row">
        <view>
          <text class="card-title">{{item.projectName || item.equipmentName || item.consumableName}}</text>
          <text class="card-subtitle">{{item.applicantName}} · {{item.createdAt}}</text>
        </view>
        <text class="status-tag {{item.statusClass}}">{{item.statusText}}</text>
      </view>
      <view class="card-line" wx:if="{{item.timeSlot}}">
        <text>{{item.date}} {{item.timeSlot}}</text>
        <text>{{item.headCount}} 人</text>
      </view>
      <view class="card-line" wx:if="{{item.borrowDate}}">
        <text>{{item.borrowWindow}}</text>
        <text class="meta-text">{{item.equipmentName}}</text>
      </view>
      <view class="card-line" wx:if="{{item.quantity}}">
        <text>{{item.quantity}}{{item.unit}}</text>
        <text class="meta-text">{{item.consumableName}}</text>
      </view>
      <text class="card-subtitle">{{item.purpose}}</text>
      <view class="btn-row">
        <button class="btn-light" data-id="{{item.id}}" bindtap="reject">驳回</button>
        <button class="btn-primary" data-id="{{item.id}}" bindtap="approve">通过</button>
      </view>
    </view>
  </block>
  <view wx:else class="empty-card">当前分类下没有待审批记录。</view>
</view>
